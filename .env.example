# CodeValdDT — environment configuration example.
# Copy this file to .env and fill in the values for your environment.
# The .env file is gitignored and must never be committed.

# -------------------------------------------------------------------
# Inbound gRPC server
# -------------------------------------------------------------------

# TCP port the CodeValdDT gRPC server listens on (REQUIRED).
CODEVALDDT_PORT=50055

# -------------------------------------------------------------------
# CodeValdCross integration
# -------------------------------------------------------------------

# gRPC address of the CodeValdCross orchestrator.
# When set, CodeValdDT calls Register on startup to announce itself.
# Leave unset to run CodeValdDT in standalone mode (no registration).
# CROSS_GRPC_ADDR=:50051

# Address that CodeValdCross will use to dial back into this service.
# Defaults to ":${CODEVALDDT_PORT}".
# DT_GRPC_ADVERTISE_ADDR=:50055

# Agency this CodeValdDT instance is scoped to.
# Included in every Register heartbeat sent to CodeValdCross so the
# registry can identify which agency each instance serves.
# Leave unset for instances that serve all agencies.
# CODEVALDDT_AGENCY_ID=utility-app-builder

# How often CodeValdDT re-registers with CodeValdCross (heartbeat).
# Accepts Go duration strings (e.g. 20s, 1m). Default: 20s.
# CROSS_PING_INTERVAL=20s

# Per-RPC timeout for each Register call. Default: 5s.
# CROSS_PING_TIMEOUT=5s

# -------------------------------------------------------------------
# ArangoDB backend
# -------------------------------------------------------------------

# ArangoDB server endpoint.
DT_ARANGO_ENDPOINT=http://localhost:8529

# ArangoDB credentials.
DT_ARANGO_USER=root
DT_ARANGO_PASSWORD=

# Database name. CodeValdDT does NOT create the database — it connects to
# an existing one and ensures its collections exist on boot.
DT_ARANGO_DATABASE=codevalddt
